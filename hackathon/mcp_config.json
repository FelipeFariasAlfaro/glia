{
  "mcpServers": {
    "glia": {
      "command": "python",
      "args": [
        "-m",
        "glia.mcp_server"
      ],
      "env": {
        "GLIA_WORKSPACE": ".",
        "GLIA_MODEL": "gemini-3.1-flash-lite-preview"
      }
    },
    "gitlab": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-gitlab"
      ],
      "env": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "YOUR_GITLAB_TOKEN_HERE",
        "GITLAB_API_URL": "https://gitlab.com"
      }
    }
  }
}
