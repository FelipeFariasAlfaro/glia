# ============================================================
# GLIA Configuration (glia.env)
# ============================================================
# This file configures GLIA's AI provider for knowledge distillation.
# Copy this file as "glia.env" in your project root.
#
# Only the "learn" command uses AI. All other commands (scan, recall,
# stats, forget, changes) work offline without any API key.
# ============================================================

# --- Provider Selection ---
# Options: gemini, openai, anthropic
# If not set, GLIA auto-detects based on which API key is present.
GLIA_PROVIDER=gemini


# --- API Keys (ONLY set the ONE for your chosen provider) ---

# Gemini (Google) - Free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# OpenAI - Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_key_here

# Anthropic (Claude) - Get key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Model (optional) ---
# If not set, uses the default for your provider:
#   gemini    → gemini-2.5-flash
#   openai    → gpt-4o-mini
#   anthropic → claude-sonnet-4-20250514
# You can use any model from your provider:

 GLIA_MODEL=gemini-3.1-flash
# GLIA_MODEL=gpt-4o
# GLIA_MODEL=claude-sonnet-4-20250514
